rules_version = '2';

// Writes from the marketing site go through Next.js API routes that use the
// Admin SDK — which bypasses these rules. Clients in the browser should have
// no direct access to Firestore, so deny everything by default.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
